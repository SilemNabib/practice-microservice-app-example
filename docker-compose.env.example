# ===========================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# ===========================================
# 
# This file contains environment variables for docker-compose.yml
# Copy this file to .env and customize for your local setup
#
# Usage:
#   1. Copy: cp docker-compose.env.example .env
#   2. Customize: nano .env
#   3. Run: docker-compose up -d
#
# ===========================================

# ===========================================
# REDIS CONFIGURATION
# ===========================================

# Redis connection settings
REDIS_HOST=microservices-redis-dev
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ===========================================
# CACHE ASIDE PATTERN TTL CONFIGURATION
# ===========================================
# These values should match Terraform configuration
# Default TTL for cached items in seconds
CACHE_TTL_DEFAULT=300

# TTL for user data cache in seconds
CACHE_TTL_USER_DATA=600

# TTL for TODO data cache in seconds
CACHE_TTL_TODO_DATA=180

# ===========================================
# MICROSERVICES CONFIGURATION
# ===========================================

# Users API
USERS_API_PORT=8081

# Auth API
AUTH_API_PORT=8083

# Todos API
TODO_API_PORT=8082

# Log Message Processor
LOG_MESSAGE_PROCESSOR_PORT=8084

# ===========================================
# JWT CONFIGURATION
# ===========================================

# JWT secret for authentication (must match between auth-api and todos-api)
JWT_SECRET=PRFT

# ===========================================
# REDIS CHANNEL CONFIGURATION
# ===========================================

# Redis channel for logging messages
REDIS_CHANNEL=log_channel

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================

# Frontend API URLs
AUTH_API_URL=http://localhost:8083
TODOS_API_URL=http://localhost:8082

# ===========================================
# ZIPKIN CONFIGURATION
# ===========================================

# Zipkin URL for distributed tracing
ZIPKIN_URL=http://localhost:9411/api/v2/spans
