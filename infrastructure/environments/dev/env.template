# ===========================================
# TEMPLATE DE VARIABLES DE ENTORNO - TERRAFORM
# ===========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo: cp env.template .env.local
# 2. Personaliza las variables según tu entorno
# 3. Ejecuta: source .env.local
# 4. Luego: terraform plan && terraform apply
#
# IMPORTANTE: .env.local está en .gitignore (no se sube al repo)

# ===========================================
# CONFIGURACIÓN OBLIGATORIA
# ===========================================

# Docker Host - DETECTAR AUTOMÁTICAMENTE
# Docker Desktop: "unix:///var/run/docker.sock"
# Colima: "unix:///Users/USERNAME/.colima/docker.sock"
export TF_VAR_docker_host="unix:///Users/USERNAME/.colima/docker.sock"

# Docker Network Subnet - CAMBIAR SI HAY CONFLICTO
# Verificar conflictos: docker network ls
export TF_VAR_docker_network_subnet="192.168.100.0/24"

# Redis Password - CAMBIAR POR UNA CONTRASEÑA SEGURA
export TF_VAR_redis_password="mi-password-segura"

# Redis Port - CAMBIAR SI 6379 ESTÁ OCUPADO
export TF_VAR_redis_port="6379"

# ===========================================
# CONFIGURACIÓN OPCIONAL
# ===========================================

# Redis Version
export TF_VAR_redis_version="7.0-alpine"

# Redis Memory Configuration
export TF_VAR_redis_memory_limit="256mb"
export TF_VAR_redis_memory_policy="allkeys-lru"

# Cache TTL Configuration (segundos)
export TF_VAR_cache_ttl_default="300"
export TF_VAR_cache_ttl_user_data="600"
export TF_VAR_cache_ttl_todo_data="180"

# ===========================================
# CONFIGURACIÓN AVANZADA
# ===========================================

# Environment
export TF_VAR_deployment_phase="local"

# Project Configuration
export TF_VAR_project_name="microservices"
export TF_VAR_environment="dev"

# ===========================================
# VARIABLES DE ENTORNO PARA TERRAFORM
# ===========================================

# Terraform Log Level (opcional)
export TF_LOG="INFO"

# Terraform Log Path (opcional)
export TF_LOG_PATH="./terraform.log"

# ===========================================
# VERIFICACIÓN
# ===========================================
# 
# Para verificar que las variables se cargaron:
# echo "Docker Host: $TF_VAR_docker_host"
# echo "Network Subnet: $TF_VAR_docker_network_subnet"
# echo "Redis Port: $TF_VAR_redis_port"
